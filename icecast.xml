<icecast>

    <!-- Basic server identity shown in web UI -->
    <location>Kathmandu</location>
    <admin>admin@localhost</admin>

    <limits>
        <!-- Maximum number of listeners allowed -->
        <clients>100</clients>

        <!-- Maximum number of audio sources (streams) that can connect -->
        <sources>2</sources>

        <!-- Buffer size for incoming stream data -->
        <queue-size>524288</queue-size>

        <!-- Timeout if a client stops responding -->
        <client-timeout>30</client-timeout>

        <!-- Timeout for HTTP headers -->
        <header-timeout>15</header-timeout>

        <!-- Timeout for source (streaming server sending audio) -->
        <source-timeout>10</source-timeout>

        <!-- Send initial burst of data to reduce startup delay -->
        <burst-on-connect>1</burst-on-connect>

        <!-- Amount of audio data sent immediately on connect -->
        <burst-size>65535</burst-size>
    </limits>

    <authentication>
        <!-- Password used by streaming source (like Liquidsoap, FFmpeg) -->
        <source-password>hackme</source-password>

        <!-- Password used for relay servers (server-to-server streaming) -->
        <relay-password>hackme</relay-password>

        <!-- Admin login credentials for web admin panel -->
        <admin-user>admin</admin-user>
        <admin-password>hackme</admin-password>
    </authentication>

    <!-- Hostname used in generated stream URLs -->
    <hostname>127.0.0.1</hostname>

    <listen-socket>
        <!-- Port where Icecast listens for incoming connections -->
        <port>8000</port>

        <!-- Bind only to local machine (not public internet) -->
        <bind-address>127.0.0.1</bind-address>
    </listen-socket>

    <http-headers>
        <!-- Allow browser apps (frontend players) to access stream (CORS) -->
        <header name="Access-Control-Allow-Origin" value="*"/>
    </http-headers>

    <!-- Allows Icecast to serve web files like status pages -->
    <fileserve>1</fileserve>

    <paths>
        <!-- Base directory of Icecast installation -->
        <basedir>/opt/homebrew/Cellar/icecast/2.4.4_3/share/icecast</basedir>

        <!-- Where logs are stored -->
        <logdir>/opt/homebrew/var/log/icecast</logdir>

        <!-- Public web files (status page, etc.) -->
        <webroot>/opt/homebrew/Cellar/icecast/2.4.4_3/share/icecast/web</webroot>

        <!-- Admin dashboard web files -->
        <adminroot>/opt/homebrew/Cellar/icecast/2.4.4_3/share/icecast/admin</adminroot>

        <!-- Redirect root URL to status page -->
        <alias source="/" destination="/status.xsl"/>
    </paths>

    <logging>
        <!-- Access logs (who is listening, requests, etc.) -->
        <accesslog>access.log</accesslog>

        <!-- Error logs (server issues, failures) -->
        <errorlog>error.log</errorlog>

        <!-- Logging detail level (3 = info level, balanced) -->
        <loglevel>3</loglevel>

        <!-- Maximum size before log rotation -->
        <logsize>10000</logsize>
    </logging>

    <security>
        <!-- Keeps server isolated from system (disabled here for simplicity) -->
        <chroot>0</chroot>
    </security>

</icecast>
